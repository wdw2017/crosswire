# crosswire demo
# Runs actual xw commands with real output
# https://github.com/charmbracelet/vhs

Output demo/demo.gif
Output demo/demo.webm

Set Shell "bash"
Set FontSize 14
Set Width 960
Set Height 600
Set Theme "Catppuccin Mocha"
Set Padding 15

Type "bash demo/demo-animated.sh"
Enter
Sleep 42s
